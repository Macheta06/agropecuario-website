    "types": ["node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/scripts/**/*", "src/config/**/*", "src/models/**/*", "src/types/**/*"],
  "exclude": ["node_modules", "dist"]
}
